# ===== Classification (Aadi's part) =====

# Data files (too large for git)
classification/*.bin
classification/*.hex
classification/*.npy
classification/*.npz
classification/*.png
!classification/results/graphs/*.png
classification/*.jpg

# Fragment datasets
classification/datasets/fragments/
classification/datasets/train/
classification/datasets/val/
classification/datasets/test/

# Prediction input/output
classification/predict_input/*.bin
classification/predictions_*.csv

# Saved models (too large for git — retrain locally)
classification/saved_models/random_forest/
classification/saved_models/cnn/
classification/saved_models/xgboost/

# Generated graphs at root of results/ (regenerated via generate_graphs.py)
classification/results/*.png
classification/results/*.pdf

# Report images (regenerated via generate_report_graphs.py)
classification/report/report_images/

